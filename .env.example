# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# Groq API key (free — get one at https://console.groq.com)
# Recommended: faster, free tier with generous limits
GROQ_API_KEY=gsk_your_key_here

# Gemini API key (optional fallback — get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy_your_key_here

# Optional: change the port (default: 3000)
PORT=3000
